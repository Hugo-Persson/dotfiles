{
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "editorMode": "vim",
  "effortLevel": "high",
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "vercel-plugin@vercel-vercel-plugin": true
  },
  "extraKnownMarketplaces": {
    "vercel-vercel-plugin": {
      "source": {
        "path": "/Users/hugo/.cache/plugins/github.com-vercel-vercel-plugin",
        "source": "directory"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "/Users/hugo/.claude/claude-notification.fish",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hugo/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/Users/hugo/.claude/claude-notification.fish",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "defaultMode": "auto",
    "deny": []
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "pnpx  @owloops/claude-powerline@latest --style=powerline",
    "type": "command"
  },
  "theme": "light"
}